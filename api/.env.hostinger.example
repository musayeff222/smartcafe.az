################################################################
# HOSTINGER PRODUCTION ENV (SmartCafe API)
# Bu dosyayı sunucuda `.env` olarak kopyalayın ve değerleri doldurun.
# Mimari: api.smartcafe.az (Laravel) + smartcafe.az (React SPA)
# Asla git'e commitlemeyin.
################################################################

APP_NAME=SmartCafe
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE='Asia/Baku'

# API subdomain
APP_URL=https://api.smartcafe.az

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

################################################################
# DATABASE — Hostinger hPanel > Databases > MySQL Databases'den alın
################################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u123456789_restoran
DB_USERNAME=u123456789_restoran
DB_PASSWORD=BURAYA_GUCLU_SIFRE

################################################################
# SESSION & SANCTUM (SPA auth)
# Frontend smartcafe.az, API api.smartcafe.az → aynı cookie jar
# için SESSION_DOMAIN baştaki nokta ile (.smartcafe.az) olmalı.
################################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.smartcafe.az
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=smartcafe.az,api.smartcafe.az
SANCTUM_TOKEN_PREFIX=

################################################################
# CORS — frontend origin'leri (credentials ile cookie gönderimi için)
################################################################
CORS_ALLOWED_ORIGINS=https://smartcafe.az,https://www.smartcafe.az
CORS_SUPPORTS_CREDENTIALS=true

################################################################
# Cache / Queue
################################################################
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

################################################################
# MAIL — Hostinger Email veya SMTP servisiniz
################################################################
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@smartcafe.az
MAIL_PASSWORD=BURAYA_EMAIL_SIFRE
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@smartcafe.az"
MAIL_FROM_NAME="${APP_NAME}"

################################################################
# AWS (kullanmıyorsanız boş kalsın)
################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
