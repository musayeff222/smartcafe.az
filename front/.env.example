# Bu dosyayı .env.production / .env.development olarak kopyalayın ve doldurun.
# Create React App sadece REACT_APP_ ile başlayan değişkenleri okur.

# Laravel API (ayrı subdomain'de çalışıyor)
REACT_APP_API_BASE_URL=https://api.smartcafe.az/api

# Laravel public storage (storage:link çıktısı)
REACT_APP_IMG_BASE_URL=https://api.smartcafe.az/storage

# Frontend'in kendi domaini
REACT_APP_DOMAIN_URL=https://smartcafe.az

# Marka / metadata (isteğe bağlı)
REACT_APP_APP_NAME=Smartcafe
# REACT_APP_BACKUP_FORMAT=smartcafe-backup
# REACT_APP_BACKUP_FILE_PREFIX=smartcafe_backup
