# Bu dosyayı .env.production / .env.development olarak kopyalayın ve doldurun.
# Create React App sadece REACT_APP_ ile başlayan değişkenleri okur.

# Laravel API (örn. https://test.smartcafe.az/api)
REACT_APP_API_BASE_URL=https://test.smartcafe.az/api

# Görsellerin serve edildiği adres (Laravel storage:link çıktısı)
REACT_APP_IMG_BASE_URL=https://test.smartcafe.az/storage

# Frontend'in kendi domaini
REACT_APP_DOMAIN_URL=https://test.smartcafe.az
