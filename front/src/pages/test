 <Modal
                className=""
                isOpen={isModalOpen}
                onClose={() => setIsModalOpen(false)}
              >
                <div className="flex justify-between mt-5">
                  <h2 className="text-lg font-semibold">{tableName}</h2>
                  <button
                    className="text-sm text-blue-600"
                    onClick={() => setShowSettings(!showSettings)}
                  >
                    Ayarlar
                  </button>
                </div>

                {/* Colde button geri sayımdan yuxarıda */}
                <div className="mt-4 flex flex-col justify-center items-center flex-wrap gap-2">
                  <h2 className="text-lg text-red-500">Sürətli Seçimler</h2>
                  <div className="mt-4 flex justify-center items-center flex-wrap gap-2">
                    {backList.map((item, index) => (
                      <div
                        key={index}
                        className="px-2 py-3 w-[170px] h-12 bg-transparent text-black rounded-lg flex justify-center items-center shadow-md hover:bg-green-900 hover:text-white hover:font-bold cursor-pointer transition"
                      >
                        <div
                          onClick={() => {
                            setMinutes(item.minutes);
                            setPricePerMinute(item.total / item.minutes);
                            setMode("backward"); // Geri sayım
                            setIsRunning(true); // Timer dərhal başlasın
                          }}
                          className="flex justify-center text-md"
                        >
                          {item.minutes} dəqiqə{" "}
                          <span>
                            <Dot />
                          </span>
                          {item.total} ₼{" "}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="mt-6 flex justify-between">
                  <CountdownTimer
                    minutes={minutes}
                    pricePerMinute={pricePerMinute}
                    mode={mode}
                    setMode={setMode}
                    isRunning={isRunning}
                    setIsRunning={setIsRunning}
                  />

                  <div className="flex flex-col">
                    <label>Qiymet</label>
                    <input
                      className="border"
                      type="text"
                      placeholder="qiymet"
                    />
                  </div>
                </div>

                {showSettings && (
                  <div className="mt-6 flex flex-col gap-4 border rounded-md p-3">
                    <div className="flex flex-col gap-2">
                      <input
                        type="number"
                        className="border px-2 py-1 rounded"
                        value={minutes}
                        onChange={(e) => setMinutes(Number(e.target.value))}
                        placeholder="Dəqiqə daxil edin"
                        min={1}
                      />
                      <input
                        type="number"
                        className="border px-2 py-1 rounded"
                        value={pricePerMinute}
                        onChange={(e) =>
                          setPricePerMinute(Number(e.target.value))
                        }
                        placeholder="Qiymət daxil edin(default 0.03qəp)"
                      />
                      <button
                        className="bg-blue-500 text-white px-3 py-1 rounded"
                        onClick={addBack}
                      >
                        Əlavə et
                      </button>
                    </div>
                  </div>
                )}
              </Modal>